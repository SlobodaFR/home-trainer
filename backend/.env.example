# PostgreSQL connection string (required)
# Example: postgresql://trainer:password@localhost:5432/trainer
DATABASE_URL=postgresql://trainer:password@localhost:5432/trainer

# Public URL of the frontend — used for CORS and OAuth2 callback (required)
FRONTEND_URL=http://localhost:5173

# Port the backend listens on (optional, default: 3000)
PORT=3000

# Node environment (optional, default: development)
# Set to "production" in Docker
NODE_ENV=development

# home-auth OAuth2 client credentials (required)
AUTH_SERVICE_URL=https://auth.sloboda.fr
AUTH_CLIENT_ID=trainer
AUTH_CLIENT_SECRET=change-me

# Secret shared with home-auth for the session revocation webhook (required)
AUTH_WEBHOOK_SECRET=change-me
